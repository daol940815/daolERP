# 운영 환경 변수 — .env 로 복사 후 값 채우기 (docker-compose.prod.yml 이 사용)
# 법인 복제 시: 이 파일 + 시스템 설정 화면만 변경하면 새 법인 적용 (기획서 1.3)
POSTGRES_USER=daolerp
POSTGRES_PASSWORD=            # 필수 — 강한 비밀번호
POSTGRES_DB=daolerp
JWT_SECRET=                   # 필수 — 64자 이상 무작위 문자열 (openssl rand -hex 48)
JWT_EXPIRES_IN=8h
WEB_PORT=80                   # HTTPS(Caddy) 사용 시 127.0.0.1:8080 으로 변경 (80 포트 양보)
DOMAIN=                       # 외부 접속(HTTPS) 시 필수 — 예: gt.daolcommerce.com (deploy/docker-compose.https.yml)
