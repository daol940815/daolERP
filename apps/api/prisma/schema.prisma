// daolERP 데이터 모델 — M1 (공통 도메인)
// 설계 원칙 (기획서 5.1/8장):
//  - 단일 법인 전제: company_id 없음. 법인 고유 값은 system_settings로.
//  - User(로그인 계정)와 Employee(인사 객체)는 1:0..1 분리.
//  - 근태 도메인은 employees만 참조 (M2+에서 추가).
//  - 시간 흐름 속성은 발효일 기준 이력(employee_histories).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── 공통 도메인 ──────────────────────────────────────────────

model User {
  id           Int       @id @default(autoincrement())
  email        String    @unique
  passwordHash String    @map("password_hash")
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  // User ↔ Employee 는 1:0..1 (외부 사용자/시스템 계정은 employee 없음)
  employeeId Int?      @unique @map("employee_id")
  employee   Employee? @relation(fields: [employeeId], references: [id])

  userRoles  UserRole[]
  accessLogs AccessLog[]
  auditLogs  AuditLog[]

  @@map("users")
}

model Employee {
  id                 Int       @id @default(autoincrement())
  empNo              String    @unique @map("emp_no")
  name               String
  email              String?
  phone              String?
  hireDate           DateTime  @map("hire_date") @db.Date
  resignDate         DateTime? @map("resign_date") @db.Date
  status             String    @default("ACTIVE") // EMPLOYEE_STATUS
  jobGradeCode       String?   @map("job_grade_code")
  jobTitleCode       String?   @map("job_title_code")
  employmentTypeCode String?   @map("employment_type_code")
  workTypeCode       String?   @map("work_type_code") // common_codes(WORK_TYPE)
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  departmentId Int?        @map("department_id")
  department   Department? @relation(fields: [departmentId], references: [id])

  jobGrade       JobGrade?       @relation(fields: [jobGradeCode], references: [code])
  jobTitle       JobTitle?       @relation(fields: [jobTitleCode], references: [code])
  employmentType EmploymentType? @relation(fields: [employmentTypeCode], references: [code])

  user            User?
  histories       EmployeeHistory[]
  headOfDepts     Department[]      @relation("DepartmentHead")

  @@map("employees")
}

// 발효일 기준 직원 변경 이력 — 과거 근태의 조직 귀속 기준 (기획서 4.1.2)
model EmployeeHistory {
  id            Int      @id @default(autoincrement())
  employeeId    Int      @map("employee_id")
  employee      Employee @relation(fields: [employeeId], references: [id])
  changeType    String   @map("change_type") // EMPLOYEE_CHANGE_TYPES
  beforeValue   Json?    @map("before_value")
  afterValue    Json?    @map("after_value")
  effectiveDate DateTime @map("effective_date") @db.Date
  reason        String
  createdBy     Int      @map("created_by") // user id
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([employeeId, effectiveDate])
  @@map("employee_histories")
}

model Department {
  id             Int       @id @default(autoincrement())
  name           String
  parentId       Int?      @map("parent_id")
  parent         Department?  @relation("DeptTree", fields: [parentId], references: [id])
  children       Department[] @relation("DeptTree")
  headEmployeeId Int?      @map("head_employee_id")
  headEmployee   Employee? @relation("DepartmentHead", fields: [headEmployeeId], references: [id])
  sortOrder      Int       @default(0) @map("sort_order")
  isActive       Boolean   @default(true) @map("is_active")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  employees Employee[]

  @@map("departments")
}

// ── 코드 (속성이 있어 전용 테이블 유지 — 직급/직책/고용형태) ──────

model JobGrade {
  code      String  @id
  name      String
  sortOrder Int     @default(0) @map("sort_order")
  isActive  Boolean @default(true) @map("is_active")

  employees Employee[]

  @@map("job_grades")
}

model JobTitle {
  code      String  @id
  name      String
  sortOrder Int     @default(0) @map("sort_order")
  isActive  Boolean @default(true) @map("is_active")

  employees Employee[]

  @@map("job_titles")
}

model EmploymentType {
  code      String  @id
  name      String
  sortOrder Int     @default(0) @map("sort_order")
  isActive  Boolean @default(true) @map("is_active")

  employees Employee[]

  @@map("employment_types")
}

// 속성 없는 열거값 공통 코드 (기획서 5.1 Code Master 원칙)
model CommonCode {
  id        Int     @id @default(autoincrement())
  groupCode String  @map("group_code")
  code      String
  name      String
  sortOrder Int     @default(0) @map("sort_order")
  isActive  Boolean @default(true) @map("is_active")

  @@unique([groupCode, code])
  @@map("common_codes")
}

// ── 권한 (기능 단위 RBAC, action + scope 분리 — 기획서 3.3) ─────

model Role {
  id   Int    @id @default(autoincrement())
  code String @unique // ROLE_CODES
  name String

  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@map("roles")
}

model Permission {
  id     Int    @id @default(autoincrement())
  action String // PERMISSION_ACTIONS
  scope  String // PERMISSION_SCOPES

  rolePermissions RolePermission[]

  @@unique([action, scope])
  @@map("permissions")
}

model RolePermission {
  roleId       Int        @map("role_id")
  permissionId Int        @map("permission_id")
  role         Role       @relation(fields: [roleId], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  userId Int  @map("user_id")
  roleId Int  @map("role_id")
  user   User @relation(fields: [userId], references: [id])
  role   Role @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
  @@map("user_roles")
}

// ── 시스템 설정 (법인 복제 시 변경 지점 — 기획서 4.13) ──────────

model SystemSetting {
  key         String   @id
  value       Json
  description String?
  updatedBy   Int?     @map("updated_by")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

// ── 스케줄러 (ERP Core Service — 기획서 5.4) ────────────────────

model SchedulerJob {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  description String?
  cron        String
  isActive    Boolean @default(true) @map("is_active")
  maxRetries  Int     @default(0) @map("max_retries")

  runs SchedulerJobRun[]

  @@map("scheduler_jobs")
}

model SchedulerJobRun {
  id             Int          @id @default(autoincrement())
  jobId          Int          @map("job_id")
  job            SchedulerJob @relation(fields: [jobId], references: [id])
  startedAt      DateTime     @default(now()) @map("started_at")
  finishedAt     DateTime?    @map("finished_at")
  status         String       @default("RUNNING") // JOB_RUN_STATUS
  processedCount Int          @default(0) @map("processed_count")
  error          String?
  triggeredBy    String       @default("SCHEDULE") @map("triggered_by") // SCHEDULE | MANUAL

  @@index([jobId, startedAt])
  @@map("scheduler_job_runs")
}

// ── 감사/접속 로그 (변경 로그와 접속 로그 분리 — 기획서 6장) ─────

model AuditLog {
  id          Int      @id @default(autoincrement())
  targetType  String   @map("target_type")
  targetId    String   @map("target_id")
  action      String // CREATE | UPDATE | DELETE | ...
  beforeValue Json?    @map("before_value")
  afterValue  Json?    @map("after_value")
  reason      String // 사유 필수 (기획서 6장)
  actorUserId Int?     @map("actor_user_id")
  actor       User?    @relation(fields: [actorUserId], references: [id])
  ip          String?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([targetType, targetId])
  @@map("audit_logs")
}

model AccessLog {
  id        Int      @id @default(autoincrement())
  userId    Int?     @map("user_id")
  user      User?    @relation(fields: [userId], references: [id])
  event     String // ACCESS_EVENTS
  detail    String?
  ip        String?
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@map("access_logs")
}
