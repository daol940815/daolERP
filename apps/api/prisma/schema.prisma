// daolERP 데이터 모델 — M1 (공통 도메인)
// 설계 원칙 (기획서 5.1/8장):
//  - 단일 법인 전제: company_id 없음. 법인 고유 값은 system_settings로.
//  - User(로그인 계정)와 Employee(인사 객체)는 1:0..1 분리.
//  - 근태 도메인은 employees만 참조 (M2+에서 추가).
//  - 시간 흐름 속성은 발효일 기준 이력(employee_histories).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── 공통 도메인 ──────────────────────────────────────────────

model User {
  id           Int       @id @default(autoincrement())
  email        String    @unique
  passwordHash String    @map("password_hash")
  isActive     Boolean   @default(true) @map("is_active")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  // User ↔ Employee 는 1:0..1 (외부 사용자/시스템 계정은 employee 없음)
  employeeId Int?      @unique @map("employee_id")
  employee   Employee? @relation(fields: [employeeId], references: [id])

  userRoles  UserRole[]
  accessLogs AccessLog[]
  auditLogs  AuditLog[]

  @@map("users")
}

model Employee {
  id                 Int       @id @default(autoincrement())
  empNo              String    @unique @map("emp_no")
  name               String
  email              String?
  phone              String?
  hireDate           DateTime  @map("hire_date") @db.Date
  resignDate         DateTime? @map("resign_date") @db.Date
  status             String    @default("ACTIVE") // EMPLOYEE_STATUS
  jobGradeCode       String?   @map("job_grade_code")
  jobTitleCode       String?   @map("job_title_code")
  employmentTypeCode String?   @map("employment_type_code")
  workTypeCode       String?   @map("work_type_code") // common_codes(WORK_TYPE)
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  departmentId Int?        @map("department_id")
  department   Department? @relation(fields: [departmentId], references: [id])

  // 정책 개별 배정 (nullable — 미지정 시 부서 → 전사 기본값. 기획서 4.1.1)
  workPolicyId  Int? @map("work_policy_id")
  workPolicy    WorkPolicy?  @relation(fields: [workPolicyId], references: [id])
  leavePolicyId Int? @map("leave_policy_id")
  leavePolicy   LeavePolicy? @relation(fields: [leavePolicyId], references: [id])

  jobGrade       JobGrade?       @relation(fields: [jobGradeCode], references: [code])
  jobTitle       JobTitle?       @relation(fields: [jobTitleCode], references: [code])
  employmentType EmploymentType? @relation(fields: [employmentTypeCode], references: [code])

  user            User?
  histories       EmployeeHistory[]
  headOfDepts     Department[]      @relation("DepartmentHead")

  // M3 관계
  workSchedules       WorkSchedule[]
  approvalAssignments ApprovalLineAssignment[]
  approvalStepDefs    ApprovalLineStep[]      @relation("StepSpecificApprover")
  applications        Approval[]              @relation("Applicant")
  approvalDecisions   ApprovalStepRecord[]    @relation("StepApprover")

  // M4 관계
  attendanceEvents      AttendanceEvent[]
  attendanceCorrections AttendanceCorrection[]

  // M5 관계
  leaveGrants   LeaveGrant[]
  leaveRequests LeaveRequest[]

  // M6 관계
  overtimeRequests OvertimeRequest[]

  @@map("employees")
}

// 발효일 기준 직원 변경 이력 — 과거 근태의 조직 귀속 기준 (기획서 4.1.2)
model EmployeeHistory {
  id            Int      @id @default(autoincrement())
  employeeId    Int      @map("employee_id")
  employee      Employee @relation(fields: [employeeId], references: [id])
  changeType    String   @map("change_type") // EMPLOYEE_CHANGE_TYPES
  beforeValue   Json?    @map("before_value")
  afterValue    Json?    @map("after_value")
  effectiveDate DateTime @map("effective_date") @db.Date
  reason        String
  createdBy     Int      @map("created_by") // user id
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([employeeId, effectiveDate])
  @@map("employee_histories")
}

model Department {
  id             Int       @id @default(autoincrement())
  name           String
  parentId       Int?      @map("parent_id")
  parent         Department?  @relation("DeptTree", fields: [parentId], references: [id])
  children       Department[] @relation("DeptTree")
  headEmployeeId Int?      @map("head_employee_id")
  headEmployee   Employee? @relation("DepartmentHead", fields: [headEmployeeId], references: [id])
  sortOrder      Int       @default(0) @map("sort_order")
  isActive       Boolean   @default(true) @map("is_active")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  // 부서 기본 정책 (기획서 4.1.3)
  workPolicyId  Int? @map("work_policy_id")
  workPolicy    WorkPolicy?  @relation(fields: [workPolicyId], references: [id])
  leavePolicyId Int? @map("leave_policy_id")
  leavePolicy   LeavePolicy? @relation(fields: [leavePolicyId], references: [id])

  employees           Employee[]
  approvalAssignments ApprovalLineAssignment[]

  @@map("departments")
}

// ── 코드 (속성이 있어 전용 테이블 유지 — 직급/직책/고용형태) ──────

model JobGrade {
  code      String  @id
  name      String
  sortOrder Int     @default(0) @map("sort_order")
  isActive  Boolean @default(true) @map("is_active")

  employees Employee[]

  @@map("job_grades")
}

model JobTitle {
  code      String  @id
  name      String
  sortOrder Int     @default(0) @map("sort_order")
  isActive  Boolean @default(true) @map("is_active")

  employees Employee[]

  @@map("job_titles")
}

model EmploymentType {
  code      String  @id
  name      String
  sortOrder Int     @default(0) @map("sort_order")
  isActive  Boolean @default(true) @map("is_active")

  employees Employee[]

  @@map("employment_types")
}

// 속성 없는 열거값 공통 코드 (기획서 5.1 Code Master 원칙)
model CommonCode {
  id        Int     @id @default(autoincrement())
  groupCode String  @map("group_code")
  code      String
  name      String
  sortOrder Int     @default(0) @map("sort_order")
  isActive  Boolean @default(true) @map("is_active")

  @@unique([groupCode, code])
  @@map("common_codes")
}

// ── 정책 모듈 [Master] (기획서 4.2/4.5/4.9, 5.1) ────────────────

// 근무정책 — 헤더. 실제 규칙 값은 버전(work_policy_versions)에 (기획서 4.2, POL-03)
model WorkPolicy {
  id       Int     @id @default(autoincrement())
  name     String
  type     String // WORK_POLICY_TYPES: FIXED | FLEX | AUTONOMOUS
  isActive Boolean @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  versions    WorkPolicyVersion[]
  employees   Employee[]
  departments Department[]

  @@map("work_policies")
}

// 근무정책 버전 — 적용 시작일 기준 이력. 근태 엔진이 일자별로 유효 버전을 참조 (기획서 5.1)
model WorkPolicyVersion {
  id            Int      @id @default(autoincrement())
  workPolicyId  Int      @map("work_policy_id")
  workPolicy    WorkPolicy @relation(fields: [workPolicyId], references: [id])
  effectiveDate DateTime @map("effective_date") @db.Date

  // 고정/시차 공통
  startTime           String? @map("start_time") // "09:00" (자율은 null)
  endTime             String? @map("end_time")   // "18:00"
  breakMinutes        Int     @default(60) @map("break_minutes")
  standardWorkMinutes Int     @default(480) @map("standard_work_minutes") // 소정근로(분)
  lateGraceMinutes    Int     @default(0) @map("late_grace_minutes")      // 지각 유예(분)
  workDays            Int[]   @default([1, 2, 3, 4, 5]) @map("work_days") // 근무 요일 0=일..6=토 (기본 월~금)

  // 시차출퇴근용 출근 허용 범위 (FLEX)
  flexStartFrom String? @map("flex_start_from") // "08:00"
  flexStartTo   String? @map("flex_start_to")   // "10:00"

  ipRestricted Boolean @default(false) @map("ip_restricted")

  reason    String
  createdBy Int      @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([workPolicyId, effectiveDate])
  @@index([workPolicyId, effectiveDate])
  @@map("work_policy_versions")
}

// 연차정책 — 발생·소멸 규칙 (휴가 유형과 분리. 기획서 4.5.2)
// 부여 기준은 입사일 확정(#1)이나 회계연도도 구조상 지원.
model LeavePolicy {
  id          Int     @id @default(autoincrement())
  name        String
  isActive    Boolean @default(true) @map("is_active")

  grantBasis      String  @default("HIRE_DATE") @map("grant_basis") // HIRE_DATE | FISCAL_YEAR
  fiscalStartMonth Int    @default(1) @map("fiscal_start_month")    // 회계연도 기준일 때 시작 월
  expireMonths    Int     @default(12) @map("expire_months")        // 사용기한(개월)
  carryOver       Boolean @default(false) @map("carry_over")        // 이월 허용
  carryOverLimit  Int?    @map("carry_over_limit")                  // 이월 한도(일)
  autoExpire      Boolean @default(true) @map("auto_expire")        // 기한 도래 자동 소멸
  promotionDays   Int[]   @default([60, 30]) @map("promotion_days") // 촉진 알림 시점(D-n)
  minUnit         Float   @default(0.5) @map("min_unit")            // 사용 단위: 1 | 0.5 | 0.25

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  employees   Employee[]
  departments Department[]

  @@map("leave_policies")
}

// 휴가 유형 — 속성 있는 정책 데이터(공통 코드 아님. 기획서 4.5.1, 5.1)
model LeaveType {
  id             Int     @id @default(autoincrement())
  code           String  @unique
  name           String
  paidType       String  @default("PAID") @map("paid_type") // PAID | UNPAID | POLICY
  deductsAnnual  Boolean @default(false) @map("deducts_annual") // 연차 잔여에서 차감하는 유형인가
  attachmentRule String  @default("NONE") @map("attachment_rule") // NONE | OPTIONAL | REQUIRED
  allowHalfDay   Boolean @default(false) @map("allow_half_day")
  sortOrder      Int     @default(0) @map("sort_order")
  isActive       Boolean @default(true) @map("is_active")

  requests LeaveRequest[]

  @@map("leave_types")
}

// ── 휴가 모듈 [Transaction] (기획서 4.5, 8장) ───────────────────

// 연차/휴가 발생 건 — 잔여는 저장하지 않고 grants − usages 로 계산 (기획서 8장)
model LeaveGrant {
  id            Int      @id @default(autoincrement())
  employeeId    Int      @map("employee_id")
  employee      Employee @relation(fields: [employeeId], references: [id])
  leaveTypeCode String   @default("ANNUAL") @map("leave_type_code")
  grantKey      String?  @unique @map("grant_key") // 자동 발생 멱등키 (직원:구분:발생일). 수동 조정은 null
  grantDate     DateTime @map("grant_date") @db.Date
  days          Float // 수동 차감 조정은 음수 허용 (기획서 LEV-06)
  expireDate    DateTime @map("expire_date") @db.Date
  reason        String
  status        String   @default("ACTIVE") // GRANT_STATUS: ACTIVE | EXHAUSTED | EXPIRED
  expiredDays   Float?   @map("expired_days") // 소멸 시점 잔여 기록
  createdAt     DateTime @default(now()) @map("created_at")

  usages LeaveUsage[]

  @@index([employeeId, status])
  @@map("leave_grants")
}

// 휴가 신청 — 상태기계 기획서 5.3 (가차감: REQUESTED 상태가 available 에서 차감됨)
model LeaveRequest {
  id          Int       @id @default(autoincrement())
  employeeId  Int       @map("employee_id")
  employee    Employee  @relation(fields: [employeeId], references: [id])
  leaveTypeId Int       @map("leave_type_id")
  leaveType   LeaveType @relation(fields: [leaveTypeId], references: [id])
  startDate   DateTime  @map("start_date") @db.Date
  endDate     DateTime  @map("end_date") @db.Date
  halfDay     Boolean   @default(false) @map("half_day") // 반차 (단일일만)
  days        Float // 근무일정 기준 산정 일수 (주말·휴일 자동 제외)
  reason      String
  status      String    @default("REQUESTED") // LEAVE_REQUEST_STATUS
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  usages LeaveUsage[]

  @@index([employeeId, startDate])
  @@map("leave_requests")
}

// 발생 건별 사용 매핑 — 선입선출(만료 임박 순) 차감 (기획서 8장)
model LeaveUsage {
  id        Int          @id @default(autoincrement())
  grantId   Int          @map("grant_id")
  grant     LeaveGrant   @relation(fields: [grantId], references: [id])
  requestId Int          @map("request_id")
  request   LeaveRequest @relation(fields: [requestId], references: [id])
  days      Float

  @@unique([grantId, requestId])
  @@map("leave_usages")
}

// 휴일 — 유형·범위 (향후 캘린더 이벤트로 이관 가능 구조. 기획서 4.9)
model Holiday {
  id           Int      @id @default(autoincrement())
  date         DateTime @db.Date
  name         String
  holidayType  String   @map("holiday_type") // HOLIDAY_TYPES
  departmentId Int?     @map("department_id") // null = 전사, 값 = 특정 부서만
  createdAt    DateTime @default(now()) @map("created_at")

  @@unique([date, departmentId])
  @@index([date])
  @@map("holidays")
}

// ── 권한 (기능 단위 RBAC, action + scope 분리 — 기획서 3.3) ─────

model Role {
  id   Int    @id @default(autoincrement())
  code String @unique // ROLE_CODES
  name String

  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@map("roles")
}

model Permission {
  id     Int    @id @default(autoincrement())
  action String // PERMISSION_ACTIONS
  scope  String // PERMISSION_SCOPES

  rolePermissions RolePermission[]

  @@unique([action, scope])
  @@map("permissions")
}

model RolePermission {
  roleId       Int        @map("role_id")
  permissionId Int        @map("permission_id")
  role         Role       @relation(fields: [roleId], references: [id])
  permission   Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model UserRole {
  userId Int  @map("user_id")
  roleId Int  @map("role_id")
  user   User @relation(fields: [userId], references: [id])
  role   Role @relation(fields: [roleId], references: [id])

  @@id([userId, roleId])
  @@map("user_roles")
}

// ── 근무일정 모듈 [Master] (기획서 4.3) ─────────────────────────

// 시프트 정의 — 교대근무 대비, 구조만 우선 (기획서 SCH-04)
model Shift {
  id        Int     @id @default(autoincrement())
  name      String
  startTime String  @map("start_time")
  endTime   String  @map("end_time")
  isActive  Boolean @default(true) @map("is_active")

  schedules WorkSchedule[]

  @@map("shifts")
}

// 근무일정 — 직원×일자. 근태 판정의 기준 데이터 (기획서 4.3).
// 정책+휴일로 자동 생성(AUTO)하거나 개별 조정(MANUAL). 재생성 시 MANUAL 보존.
model WorkSchedule {
  id           Int      @id @default(autoincrement())
  employeeId   Int      @map("employee_id")
  employee     Employee @relation(fields: [employeeId], references: [id])
  date         DateTime @db.Date
  isWorkday    Boolean  @map("is_workday")
  plannedStart String?  @map("planned_start") // "09:00" (휴무/자율은 null)
  plannedEnd   String?  @map("planned_end")
  breakMinutes Int      @default(0) @map("break_minutes")
  shiftId      Int?     @map("shift_id")
  shift        Shift?   @relation(fields: [shiftId], references: [id])
  source       String   @default("AUTO") // SCHEDULE_SOURCES: AUTO | MANUAL
  workPolicyId Int?     @map("work_policy_id") // 생성 근거 정책 (추적)
  adjustReason String?  @map("adjust_reason")  // 개별 조정 사유
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@unique([employeeId, date])
  @@index([date])
  @@map("work_schedules")
}

// ── 승인 모듈 (독립 — 전 신청 유형 공통. 기획서 4.7/5.3) ─────────

// 승인라인 템플릿 — 신청 유형별
model ApprovalLine {
  id          Int     @id @default(autoincrement())
  name        String
  requestType String  @map("request_type") // REQUEST_TYPES: LEAVE | OVERTIME | ATTENDANCE_CORRECTION
  isDefault   Boolean @default(false) @map("is_default") // 유형별 전사 기본 라인
  isActive    Boolean @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  steps       ApprovalLineStep[]
  assignments ApprovalLineAssignment[]
  approvals   Approval[]

  @@map("approval_lines")
}

// 단계 정의 — 순번 + 승인자 지정 방식 (기획서 APV-02)
model ApprovalLineStep {
  id             Int          @id @default(autoincrement())
  approvalLineId Int          @map("approval_line_id")
  approvalLine   ApprovalLine @relation(fields: [approvalLineId], references: [id], onDelete: Cascade)
  stepOrder      Int          @map("step_order")
  approverType   String       @map("approver_type") // APPROVER_TYPES: SPECIFIC | DEPT_HEAD | PARENT_DEPT_HEAD | JOB_TITLE
  approverEmployeeId  Int?     @map("approver_employee_id") // SPECIFIC 일 때
  approverEmployee    Employee? @relation("StepSpecificApprover", fields: [approverEmployeeId], references: [id])
  approverJobTitleCode String? @map("approver_job_title_code") // JOB_TITLE 일 때

  @@unique([approvalLineId, stepOrder])
  @@map("approval_line_steps")
}

// 승인라인 배정 — 직원/부서에 라인 연결 (우선순위 개인>부서>기본. 기획서 APV-03)
model ApprovalLineAssignment {
  id             Int          @id @default(autoincrement())
  approvalLineId Int          @map("approval_line_id")
  approvalLine   ApprovalLine @relation(fields: [approvalLineId], references: [id], onDelete: Cascade)
  employeeId     Int?         @map("employee_id")
  employee       Employee?    @relation(fields: [employeeId], references: [id])
  departmentId   Int?         @map("department_id")
  department     Department?  @relation(fields: [departmentId], references: [id])

  @@index([employeeId])
  @@index([departmentId])
  @@map("approval_line_assignments")
}

// 승인 인스턴스 — 신청 유형 + 신청 ID 공통. 상태기계 기획서 5.3
model Approval {
  id                  Int      @id @default(autoincrement())
  requestType         String   @map("request_type")
  requestId           Int      @map("request_id")
  applicantEmployeeId Int      @map("applicant_employee_id")
  applicant           Employee @relation("Applicant", fields: [applicantEmployeeId], references: [id])
  approvalLineId      Int?     @map("approval_line_id")
  approvalLine        ApprovalLine? @relation(fields: [approvalLineId], references: [id])
  currentStep         Int      @default(1) @map("current_step")
  status              String   @default("IN_PROGRESS") // APPROVAL_STATUS
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  stepRecords ApprovalStepRecord[]

  @@unique([requestType, requestId])
  @@index([status])
  @@map("approvals")
}

// 단계별 처리 이력 (승인자, 처리 일시, 의견. 기획서 8장)
model ApprovalStepRecord {
  id                 Int       @id @default(autoincrement())
  approvalId         Int       @map("approval_id")
  approval           Approval  @relation(fields: [approvalId], references: [id], onDelete: Cascade)
  stepOrder          Int       @map("step_order")
  approverEmployeeId Int?      @map("approver_employee_id") // 확정된 승인자
  approverEmployee   Employee? @relation("StepApprover", fields: [approverEmployeeId], references: [id])
  decision           String    @default("PENDING") // PENDING | APPROVED | REJECTED
  comment            String?
  decidedAt          DateTime? @map("decided_at")

  @@index([approverEmployeeId, decision])
  @@map("approval_step_records")
}

// ── 출퇴근 모듈 [Transaction] (기획서 4.4) ──────────────────────

// 출퇴근 이벤트 — append-only. 원본은 불변, 보정은 새 이벤트 추가 (기획서 ATT-03).
model AttendanceEvent {
  id           Int      @id @default(autoincrement())
  employeeId   Int      @map("employee_id")
  employee     Employee @relation(fields: [employeeId], references: [id])
  eventType    String   @map("event_type") // ATTENDANCE_EVENT_TYPES: CLOCK_IN | CLOCK_OUT | OUTING_START | OUTING_END
  occurredAt   DateTime @map("occurred_at") // 서버 시간 기준 (KST)
  ip           String?
  userAgent    String?  @map("user_agent")
  isCorrection Boolean  @default(false) @map("is_correction")
  correctionId Int?     @map("correction_id") // 보정 이벤트의 출처 보정 신청
  correction   AttendanceCorrection? @relation(fields: [correctionId], references: [id])
  createdAt    DateTime @default(now()) @map("created_at")

  @@index([employeeId, occurredAt])
  @@map("attendance_events")
}

// 근태 보정 신청 — 상태기계: REQUESTED → APPROVED → APPLIED / REJECTED / CANCELLED (기획서 5.3)
model AttendanceCorrection {
  id         Int      @id @default(autoincrement())
  employeeId Int      @map("employee_id")
  employee   Employee @relation(fields: [employeeId], references: [id])
  date       DateTime @db.Date // 대상 일자 (KST)
  clockIn    String?  @map("clock_in")  // 보정할 출근 시각 "HH:MM"
  clockOut   String?  @map("clock_out") // 보정할 퇴근 시각 "HH:MM"
  reason     String
  status     String   @default("REQUESTED") // CORRECTION_STATUS
  appliedAt  DateTime? @map("applied_at")
  createdAt  DateTime @default(now()) @map("created_at")

  events AttendanceEvent[]

  @@index([employeeId, date])
  @@map("attendance_corrections")
}

// ── 첨부파일 (범용 — 참조 유형 + 참조 ID. 기획서 4.8) ───────────

model Attachment {
  id         Int       @id @default(autoincrement())
  refType    String?   @map("ref_type") // 'attendance_correction' | 'leave_request' | ...
  refId      Int?      @map("ref_id")
  fileName   String    @map("file_name")
  storedPath String    @map("stored_path")
  mimeType   String    @map("mime_type")
  size       Int
  uploadedBy Int       @map("uploaded_by") // user id
  deletedAt  DateTime? @map("deleted_at")  // 논리 삭제 (기획서 4.8 — 물리 파기는 보존 기간 배치)
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([refType, refId])
  @@map("attachments")
}

// ── 초과근무 모듈 [Transaction] (기획서 4.6) ────────────────────

model OvertimeRequest {
  id              Int      @id @default(autoincrement())
  employeeId      Int      @map("employee_id")
  employee        Employee @relation(fields: [employeeId], references: [id])
  date            DateTime @db.Date // 대상 일자 (KST)
  startTime       String   @map("start_time") // "HH:MM"
  endTime         String   @map("end_time")
  expectedMinutes Int      @map("expected_minutes")
  reason          String
  status          String   @default("REQUESTED") // REQUESTED | APPROVED | REJECTED | CANCELLED
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([employeeId, date])
  @@map("overtime_requests")
}

// ── 알림 모듈 (독립 — ERP Core Service. 기획서 5.5) ─────────────

// 시스템 내 알림 (수신함)
model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  title     String
  body      String
  link      String? // 웹 라우트 (예: /approvals)
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, isRead])
  @@map("notifications")
}

// 발송 아웃박스 — 발행(업무 트랜잭션과 원자적)과 발송(스케줄러 폴링) 분리
model NotificationOutbox {
  id         Int       @id @default(autoincrement())
  userId     Int       @map("user_id")
  channel    String // NOTIFICATION_CHANNELS: INAPP | EMAIL
  template   String // 템플릿 키 (notification.templates.ts)
  params     Json
  status     String    @default("PENDING") // OUTBOX_STATUS: PENDING | SENT | FAILED | DEAD
  retryCount Int       @default(0) @map("retry_count")
  lastError  String?   @map("last_error")
  createdAt  DateTime  @default(now()) @map("created_at")
  sentAt     DateTime? @map("sent_at")

  @@index([status, createdAt])
  @@map("notification_outbox")
}

// ── 시스템 설정 (법인 복제 시 변경 지점 — 기획서 4.13) ──────────

model SystemSetting {
  key         String   @id
  value       Json
  description String?
  updatedBy   Int?     @map("updated_by")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

// ── 스케줄러 (ERP Core Service — 기획서 5.4) ────────────────────

model SchedulerJob {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  description String?
  cron        String
  isActive    Boolean @default(true) @map("is_active")
  maxRetries  Int     @default(0) @map("max_retries")

  runs SchedulerJobRun[]

  @@map("scheduler_jobs")
}

model SchedulerJobRun {
  id             Int          @id @default(autoincrement())
  jobId          Int          @map("job_id")
  job            SchedulerJob @relation(fields: [jobId], references: [id])
  startedAt      DateTime     @default(now()) @map("started_at")
  finishedAt     DateTime?    @map("finished_at")
  status         String       @default("RUNNING") // JOB_RUN_STATUS
  processedCount Int          @default(0) @map("processed_count")
  error          String?
  triggeredBy    String       @default("SCHEDULE") @map("triggered_by") // SCHEDULE | MANUAL

  @@index([jobId, startedAt])
  @@map("scheduler_job_runs")
}

// ── 월 마감 [Snapshot] (기획서 4.10, 5.3 상태기계) ──────────────

model MonthlyClosing {
  id               Int       @id @default(autoincrement())
  yearMonth        String    @unique @map("year_month") // "YYYY-MM"
  status           String    @default("OPEN") // CLOSING_STATUS: OPEN | VALIDATING | CLOSED | REOPENED
  validationResult Json?     @map("validation_result") // 마감 시점 검증 결과 (경고 포함)
  executedBy       Int?      @map("executed_by")
  closedAt         DateTime? @map("closed_at")
  reopenReason     String?   @map("reopen_reason")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  snapshots ClosingSnapshot[]

  @@map("monthly_closings")
}

// 마감 스냅샷 — 직원×월 확정 집계. 마감 후 불변, 급여 계산의 근거 (기획서 1.4)
model ClosingSnapshot {
  id              Int            @id @default(autoincrement())
  closingId       Int            @map("closing_id")
  closing         MonthlyClosing @relation(fields: [closingId], references: [id], onDelete: Cascade)
  employeeId      Int            @map("employee_id")
  empNo           String         @map("emp_no") // 마감 시점 값 고정 (직원 정보 변경과 무관)
  employeeName    String         @map("employee_name")
  departmentName  String?        @map("department_name")
  workdayCount    Int            @map("workday_count")    // 소정 근무일수
  presentDays     Int            @map("present_days")     // 출근일수
  absentDays      Int            @map("absent_days")
  lateCount       Int            @map("late_count")
  lateMinutes     Int            @map("late_minutes")
  earlyLeaveCount Int            @map("early_leave_count")
  incompleteCount Int            @map("incomplete_count")
  leaveDays       Int            @map("leave_days")
  workMinutes     Int            @map("work_minutes")
  overtimeMinutes Int            @map("overtime_minutes") // 승인된 초과근무 합
  createdAt       DateTime       @default(now()) @map("created_at")

  @@unique([closingId, employeeId])
  @@map("closing_snapshots")
}

// ── 감사/접속 로그 (변경 로그와 접속 로그 분리 — 기획서 6장) ─────

model AuditLog {
  id          Int      @id @default(autoincrement())
  targetType  String   @map("target_type")
  targetId    String   @map("target_id")
  action      String // CREATE | UPDATE | DELETE | ...
  beforeValue Json?    @map("before_value")
  afterValue  Json?    @map("after_value")
  reason      String // 사유 필수 (기획서 6장)
  actorUserId Int?     @map("actor_user_id")
  actor       User?    @relation(fields: [actorUserId], references: [id])
  ip          String?
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([targetType, targetId])
  @@map("audit_logs")
}

model AccessLog {
  id        Int      @id @default(autoincrement())
  userId    Int?     @map("user_id")
  user      User?    @relation(fields: [userId], references: [id])
  event     String // ACCESS_EVENTS
  detail    String?
  ip        String?
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@map("access_logs")
}
