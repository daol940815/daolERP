# ───────────────────────────────────────────────────────────
# daolERP 환경변수 예시
# 이 파일을 복사해 ".env" 로 만들고 값을 채우세요. (.env 는 깃에 올라가지 않습니다)
# 운영(Vercel)에서는 이 값들을 Vercel 프로젝트의 Environment Variables 에 등록합니다.
# ───────────────────────────────────────────────────────────

# [필수] PostgreSQL 연결 주소
#  - Neon 사용 시: 애플리케이션용은 "Pooled connection"(-pooler 포함) 주소
#  - 로컬 개발 시: postgresql://daol:daolpw@127.0.0.1:5432/daolerp?schema=public
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# [필수] 마이그레이션용 직접 연결 주소
#  - Neon 사용 시: "Direct connection"(-pooler 없는) 주소
#  - 로컬 개발 시: DATABASE_URL 과 동일하게 두어도 됩니다
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# [필수] 로그인 세션 서명 키 (길고 무작위한 문자열)
#  - 생성 예시:  openssl rand -base64 32
AUTH_SECRET="여기에-길고-무작위한-비밀키를-넣으세요"

# [필수] 최초 관리자 계정 (배포/시드 시 자동 생성·갱신)
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="여기에-강력한-비밀번호"
ADMIN_NAME="관리자"

# [선택/향후] 첨부파일 저장용 오브젝트 스토리지 (Cloudflare R2 / AWS S3 호환)
#  - 현재는 사용하지 않습니다. 향후 첨부파일 기능 추가 시 활성화.
# STORAGE_ENDPOINT=""
# STORAGE_BUCKET=""
# STORAGE_ACCESS_KEY_ID=""
# STORAGE_SECRET_ACCESS_KEY=""
# STORAGE_PUBLIC_BASE_URL=""
